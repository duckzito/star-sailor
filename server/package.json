{
  "name": "@star-sailor/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:express --external:colyseus --external:@colyseus/ws-transport",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@star-sailor/shared": "*",
    "colyseus": "^0.15.57",
    "@colyseus/ws-transport": "^0.15.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}
